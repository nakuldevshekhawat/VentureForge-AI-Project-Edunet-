# =============================================================================
# VentureForge AI – Environment Variables Template
# =============================================================================

# Flask Session Security Configuration
FLASK_SECRET_KEY=your_super_secret_session_key_here

# Flask App Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# Allowed origins for CORS (comma separated, e.g., http://localhost:3000)
ALLOWED_ORIGINS=*

# IBM watsonx.ai Credentials (Required)
IBM_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx.ai Optional Parameters
# Default region endpoint is us-south (Dallas)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
# Default model: meta-llama/llama-3-3-70b-instruct or ibm/granite-3-3-8b-instruct
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# LLM Generation Parameters
MAX_NEW_TOKENS=3000
TEMPERATURE=0.7
TOP_P=0.9
